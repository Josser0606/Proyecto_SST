PORT=3000

DB_HOST=your-tidb-host
DB_PORT=4000
DB_USER=your-tidb-user
DB_PASSWORD=your-tidb-password
DB_NAME=your-database-name

# JWT
JWT_SECRET=change-me
JWT_EXPIRES_IN=8h
AUTH_HEADER_NAME=authorization
TRUST_PROXY=1

# Rate limit
LOGIN_RATE_LIMIT_WINDOW_MS=600000
LOGIN_RATE_LIMIT_MAX=30
API_RATE_LIMIT_WINDOW_MS=300000
API_RATE_LIMIT_MAX=600

# Login lockout
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

# Ventana para confirmar lectura desde fecha de publicacion (en dias)
READ_CONFIRM_WINDOW_DAYS=2

# Comma-separated list
FRONTEND_URLS=https://tu-app.vercel.app,http://localhost:5173
ALLOW_LOCAL_ORIGINS=true

# Set true to allow all *.vercel.app preview domains
ALLOW_VERCEL_PREVIEW=true

# Cloudinary (imagenes persistentes)
# Opcion 1: usar URL completa
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
#
# Opcion 2: usar credenciales separadas
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret
#
# Carpeta destino opcional
# CLOUDINARY_FOLDER=saciar

# Cloudflare R2 (adjuntos persistentes: PDF, Word, Excel, PowerPoint)
# Si completas estas variables, los archivos adjuntos se guardaran en R2.
# R2_ACCOUNT_ID=tu_account_id
# R2_ACCESS_KEY_ID=tu_access_key_id
# R2_SECRET_ACCESS_KEY=tu_secret_access_key
# R2_BUCKET=nombre-del-bucket
# URL publica base del bucket o dominio publico conectado a R2
# Ejemplo: https://pub-xxxxxxxx.r2.dev
# R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev
# Carpeta opcional dentro del bucket
# R2_ATTACHMENTS_PREFIX=comunicados

# Notificaciones por email (cola robusta)
EMAIL_NOTIFICATIONS_ENABLED=true
APP_FRONTEND_URL=https://tu-app.vercel.app

# SMTP (Resend/SendGrid/Brevo o servidor corporativo)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=usuario_smtp
SMTP_PASS=contrasena_smtp
SMTP_FROM_EMAIL=notificaciones@fundacionsaciar.org
SMTP_FROM_NAME=Fundacion Saciar

# Cola de envio
EMAIL_QUEUE_BATCH_SIZE=15
EMAIL_MAX_ATTEMPTS=5
EMAIL_RETRY_MINUTES=10
EMAIL_QUEUE_POLL_MS=45000
